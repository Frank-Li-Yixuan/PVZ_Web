{
  "name": "sprout-and-steel-v01",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite --config client/vite.config.ts --host 127.0.0.1 --port 5173",
    "server": "tsx server/src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "npm run typecheck && vite build --config client/vite.config.ts"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "phaser": "^3.90.0",
    "socket.io": "^4.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  },
  "devDependencies": {
    "@types/node": "^24.10.1"
  }
}
